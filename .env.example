# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env — ele já está no .gitignore.

# --- Auth ---
PRIMARY_JWT_SECRET_KEY=troque-por-uma-string-aleatoria-longa
PREVIOUS_JWT_SECRET_KEY=            # opcional, usado durante rotação de chaves

# --- LLM Providers ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...               # necessário para o EmbeddingClient

# --- Milvus ---
# Desenvolvimento local com Milvus Lite (sem Docker):
MILVUS_URI=./licitacoes.db
# Produção com Milvus standalone (Docker Compose):
# MILVUS_URI=http://localhost:19530

# --- Temporal ---
# Desenvolvimento local:
TEMPORAL_HOST=localhost:7233
# Dentro do Docker Compose (se o worker também rodar em container):
# TEMPORAL_HOST=temporal:7233

# --- Postgres ---
DATABASE_URL=postgresql+asyncpg://postgres:secret@localhost:5432/multi_tenant_agent
